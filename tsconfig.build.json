{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "declaration": false,
    "lib": ["ESNext"],
    "baseUrl": ".",
    "paths": {
      "@workbench/server": ["./server/index.ts"]
    }
  },
  "include": ["server", "cli"],
  "exclude": ["**/*.test.ts", "**/*.spec.ts"]
}
