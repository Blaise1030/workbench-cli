{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "jsx": "preserve",
    "lib": ["ESNext", "DOM"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./frontend/src/*"],
      "@server/*": ["./server/*"],
      "@workbench/server": ["./server/index.ts"]
    }
  },
  "include": ["frontend/src", "server", "cli", "frontend/vite.config.ts", "scripts"]
}
