---
import '../styles/global.css';
import SiteHeader from '../components/SiteHeader.astro';

interface Props {
  title: string;
  description: string;
  fullWidth?: boolean;
}

import { withBase } from '../lib/paths';

const { title, description, fullWidth = false } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
  </head>
  <body>
    <div class="min-h-screen">

      <SiteHeader />
      <!-- Content — constrained -->
      <div class={fullWidth ? 'w-full min-w-0 overflow-x-hidden sm:px-8 px-4 py-4' : 'max-w-3xl min-w-0 overflow-x-hidden sm:px-8 px-4 py-4'}>      
        <slot />

        <!-- Footer -->
        <div class="text-[hsl(var(--muted-foreground))] my-2">~~~</div>
        <div class="text-[hsl(var(--muted-foreground))]">~*~ © 2026 WORKBENCH ~*~</div>

      </div>
    </div>
  </body>
</html>
