---
import '../styles/global.css';
import type { CollectionEntry } from 'astro:content';
import SiteHeader from '../components/SiteHeader.astro';
import MarkdownLink from '../components/MarkdownLink.astro';

interface Props {
  title: string;
  description: string;
  allDocs: CollectionEntry<'docs'>[];
  currentSlug: string;
}

const { title, description, allDocs, currentSlug } = Astro.props;
const sorted = [...allDocs].sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} — Workbench</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <div class="min-h-screen flex flex-col">

      <SiteHeader />

      <!-- Two-column body — constrained -->
      <div class="max-w-5xl w-full sm:px-8 px-4 pb-8 flex-1">
        <div class="flex gap-12 max-sm:flex-col">

          <!-- Sidebar -->
          <aside class="w-44 max-sm:w-full shrink-0">
            <details open>
              <summary class="font-semibold tracking-[0.04em] mb-2 cursor-pointer">DOCS:</summary>
              <ul>
                {sorted.map(entry => {
                  const isActive = entry.slug === currentSlug;
                  return (
                    <li class={isActive ? 'font-semibold' : 'font-normal'}>
                      <MarkdownLink
                        label={`${isActive ? '> ' : ''}${entry.data.title}`}
                        href={`/docs/${entry.slug}`}
                      />
                    </li>
                  );
                })}
              </ul>
            </details>
          </aside>

          <!-- Content -->
          <main class="flex-1 min-w-0">
            <div class="font-semibold tracking-[0.04em] mb-4">{title.toUpperCase()}:</div>
            <div class="prose-docs text-[hsl(var(--muted-foreground))]">
              <slot />
            </div>
          </main>

        </div>
      </div>

      <!-- Footer — full width -->
      <div class="w-full sm:px-8 px-4 pb-8">
        <div class="text-[hsl(var(--muted-foreground))] my-2">~~~</div>
        <div class="text-[hsl(var(--muted-foreground))]">~*~ © 2026 WORKBENCH ~*~</div>
      </div>

    </div>
  </body>
</html>
