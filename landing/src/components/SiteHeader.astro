---
import MarkdownLink from './MarkdownLink.astro';

const path = Astro.url.pathname;
const isHome = path === '/' || path === '/workbench-cli/' || path === import.meta.env.BASE_URL || path === import.meta.env.BASE_URL + '/';
const isDocs = path.startsWith('/docs') || path.startsWith(import.meta.env.BASE_URL + '/docs');
const isReleases = path.startsWith('/releases') || path.startsWith(import.meta.env.BASE_URL + '/releases');
---
<header class="w-full sm:px-8 px-4 py-4 pb-3 max-sm:py-6">
  <div class="flex justify-between items-start">
    <div class="font-semibold leading-snug">
      <div class="flex gap-2 items-center">
        <h1>WORKBENCH</h1>
        <span class="w-2 h-4 -mt-0.5 bg-foreground animate-blink" aria-hidden="true"></span>
      </div>
      <div class="text-[hsl(var(--muted-foreground))] font-normal">BROWSER-NATIVE AI WORKSPACE</div>
      <div class="text-[hsl(var(--muted-foreground))] font-normal">2026</div>
    </div>
    <nav class="font-semibold leading-snug text-right">
      {!isHome && <MarkdownLink label="Home" href="/" />}
      {!isDocs && <MarkdownLink label="Docs" href="/docs" />}
      {!isReleases && <MarkdownLink label="Releases" href="/releases" />}
      <MarkdownLink label="Source" href="https://github.com/Blaise1030/workbench-cli" />
    </nav>
  </div>
</header>
<div class="sm:px-8 px-4 text-[hsl(var(--muted-foreground))] mt-4">~~~</div>
