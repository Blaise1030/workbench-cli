---
import { Image } from 'astro:assets';
import prometheusPainting from '../assets/prometheus-painting.png';

const base = import.meta.env.BASE_URL;

const tabs = [
  { label: 'WORKTREES',   src: `${base}/assets/workbench-screenshot.png`,         srcLight: `${base}/assets/workbench-screenshot-light.png` },
  { label: 'FILE EDITOR', src: `${base}/assets/screenshot-git-diff.png`,           srcLight: `${base}/assets/screenshot-git-diff-light.png` },
  { label: 'CMD PALETTE', src: `${base}/assets/screenshot-command-palette.png`,    srcLight: `${base}/assets/screenshot-command-palette-light.png` },
  { label: 'GIT DIFF',   src: `${base}/assets/screenshot-session-restore.png`,    srcLight: `${base}/assets/screenshot-session-restore-light.png` },
];

const id = `feature-pan-${Math.random().toString(36).slice(2, 7)}`;
---

<div class="w-full" id={id}>
  <!-- Tabs -->
  <div class="flex gap-3 max-w-2xl mx-auto sm:px-0 px-4 mb-1.5 font-mono text-[10px] tracking-[0.08em] flex-wrap justify-center" style="position:relative;z-index:1;">
    {tabs.map((t, i) => (
      <button
        class="tab-btn shrink-0 cursor-pointer select-none transition-colors text-[hsl(var(--muted-foreground))] hover:text-[hsl(var(--foreground))]"
        data-index={i}
      >
        {t.label}
      </button>
    ))}
  </div>
  <!-- Painting background + browser -->
  <div class="p-2 sm:p-6 overflow-hidden" style="position:relative;">
    <Image
      src={prometheusPainting}
      alt=""
      format="webp"
      aria-hidden="true"
      style="position:absolute;inset:0;z-index:0;width:100%;height:100%;object-fit:cover;object-position:center;"
    />
    <div class="rounded-[6px] overflow-hidden shadow-2xl" style="position:relative;z-index:2;">
      <div class="flex items-center gap-1 px-2 py-1 bg-muted border-b">
        <div class="flex gap-1.5 shrink-0">
          <span class="w-2.5 h-2.5 rounded-full border"></span>
          <span class="w-2.5 h-2.5 rounded-full border"></span>
          <span class="w-2.5 h-2.5 rounded-full border"></span>
        </div>
        <div class="flex-1 flex items-center gap-1.5 bg-background border rounded-[4px] px-2 py-0.5 ml-1">
          <svg width="9" height="9" viewBox="0 0 16 16" fill="none" class="shrink-0 opacity-40"><circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.5"/><path d="M8 4v4l2.5 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          <span class="font-mono text-[9px] text-foreground">localhost:4739</span>
        </div>
      </div>
      <div class="relative w-full">
        {tabs.map((t, i) => (
          <picture class={`tab-img w-full block ${i === 0 ? '' : 'hidden'}`} data-index={i}>
            <source srcset={t.srcLight} media="(prefers-color-scheme: light)" />
            <img src={t.src} alt={t.label} class="w-full block" />
          </picture>
        ))}
      </div>
    </div>
  </div>
</div>

<script define:vars={{ id }}>
  const root = document.getElementById(id);
  const btns = root.querySelectorAll('.tab-btn');
  const imgs = root.querySelectorAll('.tab-img');

  function activate(idx) {
    btns.forEach((b, i) => {
      b.style.color = i === idx ? 'hsl(var(--foreground))' : '';
      b.style.textDecoration = i === idx ? 'underline' : '';
    });
    imgs.forEach((img, i) => img.classList.toggle('hidden', i !== idx));
  }

  activate(0);
  btns.forEach(btn => btn.addEventListener('click', () => activate(Number(btn.dataset.index))));
</script>
