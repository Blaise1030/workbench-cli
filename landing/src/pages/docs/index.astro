---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { withBase } from '../../lib/paths';

const allDocs = await getCollection('docs');
const sorted = allDocs.sort((a, b) => a.data.order - b.data.order);
---

<Layout title="Docs — Workbench" description="Workbench documentation">
  <div class="font-semibold tracking-[0.04em]">DOCS:</div>
  {sorted.map(entry => (
    <div class="flex pl-[1ch] text-[hsl(var(--muted-foreground))]">
      <span class="shrink-0 text-[hsl(var(--foreground))]"> -</span>
      <span>
        <span class="whitespace-nowrap">{'['}<a href={withBase(`/docs/${entry.slug}`)}>{entry.data.title}</a>{']'}</span>
        {entry.data.description && <span> — {entry.data.description}</span>}
      </span>
    </div>
  ))}  

</Layout>
