---
import Layout from '../layouts/Layout.astro';
import MarkdownLink from '../components/MarkdownLink.astro';
const installCmd = 'curl -fsSL https://blaise1030.github.io/workbench-cli/install.sh | sh';

const compareColumns = ['TOOL', 'WORKTREE-FIRST', 'AGENT AWARE', 'PARALLEL AGENTS'];
const links = [
  { label: 'Docs',      href: '/docs' },
  { label: 'Source',    href: 'https://github.com/Blaise1030/workbench-cli' },
  { label: 'Releases',  href: '/releases' },
  { label: 'Changelog', href: '/changelog' },
];

const compareRows = [
  { tool: 'Workbench',              highlight: true,  values: [true,  true,  true]  },
  { tool: 'Tower / GitHub Desktop', highlight: false, values: [false, false, false] },
  { tool: 'herdr',                  highlight: false, values: [true,  true,  false] },
  { tool: 'Cursor / VS Code',       highlight: false, values: [false, true,  false] },
];
---

<Layout title="Workbench" description="Mission control for parallel AI coding. Workbench is a GUI workspace manager for engineers running multiple Claude Code agents in parallel across git worktrees.">

        <!-- Meta -->
        <div><span class="font-semibold tracking-[0.04em]">PRODUCT:</span> <span class="text-[hsl(var(--muted-foreground))]">GUI WORKSPACE MANAGER FOR AI-DRIVEN DEVELOPMENT</span></div>
        <div><span class="font-semibold tracking-[0.04em]">STATUS:</span> <span class="text-[hsl(var(--muted-foreground))]">AVAILABLE</span></div>
        <div><span class="font-semibold tracking-[0.04em]">VERSION:</span> <span class="text-[hsl(var(--muted-foreground))]">0.1.0</span></div>
        <div><span class="font-semibold tracking-[0.04em]">PLATFORM:</span> <span class="text-[hsl(var(--muted-foreground))]">MACOS</span></div>

        <div class="text-[hsl(var(--muted-foreground))] my-[14px]">~~~</div>
           <!-- Install -->
        <div class="font-semibold tracking-[0.04em]">INSTALL:</div>
        <div class="flex items-center gap-3 pl-[1ch] mb-1 max-sm:flex-col max-sm:items-start max-sm:gap-[6px]">
          <span class="font-medium text-[12px] bg-muted max-sm:text-[11px] max-sm:break-all" id="install-cmd">{installCmd}</span>
          <button
            class="font-[inherit] text-[10px] tracking-[0.1em] bg-foreground text-background border-0 px-2 py-0.5 cursor-pointer rounded-[2px] shrink-0 hover:opacity-80"
            aria-label="Copy install command"
          >COPY</button>
        </div>
        <MarkdownLink label="Install options" href="https://blaise1030.github.io/workbench-cli/" />
        <MarkdownLink label="Releases" href="/releases" />

        <div class="text-[hsl(var(--muted-foreground))] my-[14px]">~~~</div>

        <!-- About -->
        <div class="font-semibold tracking-[0.04em]">ABOUT:</div>
        <div class="text-[hsl(var(--muted-foreground))] pl-[1ch]">Mission control for parallel AI coding. Workbench is a single GUI for every git worktree, every Claude Code agent, and every running branch — all at once. No more juggling terminal windows. No more losing track of which agent is working on what.</div>
        <div class="text-[hsl(var(--muted-foreground))] pl-[1ch]">Built for engineers running Claude Code at scale. Keep your editor; add one place to see everything.</div>

        <div class="text-[hsl(var(--muted-foreground))] my-[14px]">~~~</div>

        <!-- Features -->
        <div class="font-semibold tracking-[0.04em]">FEATURES:</div>
        <div class="text-[hsl(var(--muted-foreground))] pl-[1ch]"><span class="text-[hsl(var(--foreground))]"> -</span> Parallel git worktrees, tracked in one sidebar</div>
        <div class="text-[hsl(var(--muted-foreground))] pl-[1ch]"><span class="text-[hsl(var(--foreground))]"> -</span> Claude Code hook integration — get notified when agents stop or complete tasks</div>
        <div class="text-[hsl(var(--muted-foreground))] pl-[1ch]"><span class="text-[hsl(var(--foreground))]"> -</span> Per-worktree terminal tabs, git panel, and file explorer</div>
        <div class="text-[hsl(var(--muted-foreground))] pl-[1ch]"><span class="text-[hsl(var(--foreground))]"> -</span> Line-level diffs, staged/unstaged review without leaving the app</div>
        <div class="text-[hsl(var(--muted-foreground))] pl-[1ch]"><span class="text-[hsl(var(--foreground))]"> -</span> Keybinding configuration and LAN network settings</div>
        <div class="text-[hsl(var(--muted-foreground))] pl-[1ch]"><span class="text-[hsl(var(--foreground))]"> -</span> Single binary — no Electron, no runtime dependencies</div>

        <div class="text-[hsl(var(--muted-foreground))] my-[14px]">~~~</div>

        <!-- How it compares -->
        <div class="font-semibold tracking-[0.04em]">HOW IT COMPARES:</div>
        <div class="pl-[1ch] overflow-x-auto">
          <table class="border-collapse text-[hsl(var(--muted-foreground))] text-[12px]">
            <thead>
              <tr class="text-[hsl(var(--foreground))]">
                {compareColumns.map(col => (
                  <th class="text-left font-semibold pr-6 pb-1 border-b border-[hsl(var(--border))]">{col}</th>
                ))}
              </tr>
            </thead>
            <tbody>
              {compareRows.map(row => (
                <tr class={row.highlight ? 'text-[hsl(var(--foreground))] font-semibold' : ''}>
                  <td class={`pr-6 pt-1${row.highlight ? ' border-b border-[hsl(var(--border))]' : ''}`}>{row.tool}</td>
                  {row.values.map(val => (
                    <td class={`pr-6 pt-1${row.highlight ? ' border-b border-[hsl(var(--border))]' : ''}`}>{val ? '✓' : '✗'}</td>
                  ))}
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <div class="text-[hsl(var(--muted-foreground))] my-[14px]">~~~</div>

        <!-- Links -->
        <div class="font-semibold tracking-[0.04em]">LINKS:</div>
        {links.map(link => (
          <MarkdownLink label={link.label} href={link.href} />
        ))}

    <script>
      const btn = document.querySelector('button[aria-label="Copy install command"]') as HTMLButtonElement | null;
      const cmdEl = document.getElementById('install-cmd');
      btn?.addEventListener('click', () => {
        const cmd = cmdEl?.textContent ?? '';
        navigator.clipboard.writeText(cmd).then(() => {
          if (btn) { btn.textContent = 'COPIED'; setTimeout(() => { btn.textContent = 'COPY'; }, 1500); }
        }).catch(() => {
          if (btn) { btn.textContent = 'ERR'; setTimeout(() => { btn.textContent = 'COPY'; }, 1500); }
        });
      });
    </script>
</Layout>
