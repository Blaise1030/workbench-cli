---
import Layout from '../layouts/Layout.astro';
import MarkdownLink from '../components/MarkdownLink.astro';
import { installCmd, installChannelLabel, isDevPreviewBuild } from '../lib/install';

const compareTools = ['Workbench', 'tmux', 'Conductor', 'herdr', 'T3 Code'];
const compareRows = [
  { feature: 'BROWSER-BASED',      values: [true,  false, false, false, false] },
  { feature: 'LINUX',              values: [true,  true,  false, true,  true]  },
  { feature: '<20MB',              values: [true,  true,  false, true,  null]  },
  { feature: 'FILE EDITOR',        values: [true,  false, false, false, true]  },
  { feature: 'GIT DIFF',          values: [true,  false, false, false, true]  },
  { feature: 'PARALLEL WORKTREES', values: [true,  false, true,  false, true]  },
  { feature: 'AGENT STATUS',       values: [true,  false, false, true,  null]  },
];
const links = [
  { label: 'Docs',     href: '/docs' },
  { label: 'Source',   href: 'https://github.com/Blaise1030/workbench-cli' },
  { label: 'Releases', href: '/releases' },
];
---

<Layout title="Workbench" description="A browser tab, not another app. Workbench is a lightweight workspace for AI coding agents — worktrees, terminals, file editor, and git diffs in one place. Under 20MB. Runs on Linux.">

        <!-- Install -->
        <div class="font-semibold mb-2 tracking-[0.04em]">INSTALL{isDevPreviewBuild ? ` (${installChannelLabel})` : ''}:</div>
        {isDevPreviewBuild && (
          <div class="text-[hsl(var(--muted-foreground))] pl-[1ch] text-[11px] mb-1">
            PR preview — installs this build. For the latest stable release use
            {' '}<span class="text-black-200">curl -fsSL https://blaise1030.github.io/workbench-cli/install.sh | sh</span>
          </div>
        )}
        <div class="pl-[1ch] leading-relaxed">
          <span class="font-medium p-1 bg-muted text-black break-all box-decoration-clone" id="install-cmd">{installCmd}</span><!--
          --><button
            class="inline-block align-middle ms-2 tracking-[0.1em] bg-foreground text-background border-0 px-1 cursor-pointer hover:opacity-80"
            aria-label="Copy install command"
          >COPY</button>
        </div>        

        <div class="text-[hsl(var(--muted-foreground))] my-[14px]">~~~</div>

        <!-- About -->
        <div class="font-semibold tracking-[0.04em]">ABOUT:</div>
        <div class="text-[hsl(var(--muted-foreground))] pl-[1ch]">A browser tab, not another app. Workbench is a lightweight Go binary that serves your entire AI coding workspace in a browser — worktrees, terminals, file editor, and git diffs, all in one place.</div>
        <div class="text-[hsl(var(--muted-foreground))] pl-[1ch]">Works with any agent: Claude Code, Codex, Aider, OpenCode, or anything that runs in a terminal. Under 20MB. No Electron. Runs on Linux.</div>

        <div class="text-[hsl(var(--muted-foreground))] my-[14px]">~~~</div>

        <!-- Features -->
        <div class="font-semibold tracking-[0.04em]">FEATURES:</div>
        <div class="flex pl-[1ch] text-[hsl(var(--muted-foreground))]"><span class="shrink-0 text-[hsl(var(--foreground))]"> -</span><span>Parallel git worktrees with one-click switching</span></div>
        <div class="flex pl-[1ch] text-[hsl(var(--muted-foreground))]"><span class="shrink-0 text-[hsl(var(--foreground))]"> -</span><span>Real terminal per worktree — run any agent (Claude Code, Codex, Aider, OpenCode)</span></div>
        <div class="flex pl-[1ch] text-[hsl(var(--muted-foreground))]"><span class="shrink-0 text-[hsl(var(--foreground))]"> -</span><span>Built-in file editor with syntax highlighting</span></div>
        <div class="flex pl-[1ch] text-[hsl(var(--muted-foreground))]"><span class="shrink-0 text-[hsl(var(--foreground))]"> -</span><span>Line-level git diffs, staged/unstaged — no app switch needed</span></div>
        <div class="flex pl-[1ch] text-[hsl(var(--muted-foreground))]"><span class="shrink-0 text-[hsl(var(--foreground))]"> -</span><span>Command palette</span></div>
        <div class="flex pl-[1ch] text-[hsl(var(--muted-foreground))]"><span class="shrink-0 text-[hsl(var(--foreground))]"> -</span><span>Agent notifications — get alerted when agents complete or stop</span></div>
        <div class="flex pl-[1ch] text-[hsl(var(--muted-foreground))]"><span class="shrink-0 text-[hsl(var(--foreground))]"> -</span><span>Single binary, no Electron, no runtime dependencies</span></div>

        <div class="text-[hsl(var(--muted-foreground))] my-[14px]">~~~</div>

        <!-- How it compares -->
        <div class="font-semibold tracking-[0.04em]">HOW IT COMPARES:</div>
        <div class="relative mt-2 min-w-0 max-w-full overflow-hidden">
          <div id="compare-scroll" class="w-full min-w-0 overflow-x-auto px-[1ch] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
          <table class="border-collapse w-full text-[hsl(var(--muted-foreground))] text-[12px]">
            <thead>
              <tr class="text-[hsl(var(--foreground))]">
                <th class="text-left font-semibold pr-6 pb-1 border-b border-[hsl(var(--border))] whitespace-nowrap">FEATURE</th>
                {compareTools.map((tool, i) => (
                  <th class={`text-center font-semibold pr-6 pb-1 border-b border-[hsl(var(--border))] whitespace-nowrap${i === 0 ? ' text-[hsl(var(--foreground))]' : ''}`}>{tool}</th>
                ))}
              </tr>
            </thead>
            <tbody>
              {compareRows.map(row => (
                <tr>
                  <td class="pr-6 pt-1 text-[hsl(var(--foreground))] font-semibold whitespace-nowrap">{row.feature}</td>
                  {row.values.map((val, i) => (
                    <td class={`text-center pr-6 pt-1 whitespace-nowrap${i === 0 ? ' text-[hsl(var(--foreground))] font-bold' : ''}`}>{val === null ? '?' : val ? '✓' : '✗'}</td>
                  ))}
                </tr>
              ))}
            </tbody>
          </table>
          </div>
          <div id="fade-left" class="compare-table-fade compare-table-fade--left" aria-hidden="true"></div>
          <div id="fade-right" class="compare-table-fade compare-table-fade--right" aria-hidden="true"></div>
        </div>

        <div class="text-[hsl(var(--muted-foreground))] my-[14px]">~~~</div>

        <!-- Links -->
        <div class="font-semibold tracking-[0.04em]">LINKS:</div>
        {links.map(link => (
          <MarkdownLink label={link.label} href={link.href} showHref={true} />
        ))}

    <script is:inline>
      (function () {
        const scroll = document.getElementById('compare-scroll');
        const fadeLeft = document.getElementById('fade-left');
        const fadeRight = document.getElementById('fade-right');
        if (!scroll || !fadeLeft || !fadeRight) return;

        function updateFades() {
          const { scrollLeft, scrollWidth, clientWidth } = scroll;
          const canScroll = scrollWidth > clientWidth + 1;
          const showLeft = canScroll && scrollLeft > 2;
          const showRight = canScroll && scrollLeft + clientWidth < scrollWidth - 2;
          fadeLeft.classList.toggle('is-visible', showLeft);
          fadeRight.classList.toggle('is-visible', showRight);
          fadeLeft.setAttribute('aria-hidden', showLeft ? 'false' : 'true');
          fadeRight.setAttribute('aria-hidden', showRight ? 'false' : 'true');
        }

        scroll.addEventListener('scroll', updateFades, { passive: true });
        new ResizeObserver(updateFades).observe(scroll);
        window.addEventListener('resize', updateFades, { passive: true });
        document.fonts?.ready.then(updateFades);
        updateFades();
        requestAnimationFrame(updateFades);
      })();

      const btn = document.querySelector('button[aria-label="Copy install command"]');
      const cmdEl = document.getElementById('install-cmd');
      btn?.addEventListener('click', () => {
        const cmd = cmdEl?.textContent ?? '';
        navigator.clipboard.writeText(cmd).then(() => {
          btn.textContent = 'COPIED';
          setTimeout(() => { btn.textContent = 'COPY'; }, 1500);
        }).catch(() => {
          btn.textContent = 'ERR';
          setTimeout(() => { btn.textContent = 'COPY'; }, 1500);
        });
      });
    </script>
</Layout>
