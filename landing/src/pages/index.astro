---
import '../styles/global.css';
import rawContent from '../content/landing.md?raw';

// Convert markdown links [text](url) to HTML
function parseLinks(text: string): string {
  return text.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2">$1</a>');
}

// Split content into sections on ~~~
const sections = rawContent.split(/\n~~~\n/).map(s => s.trim()).filter(Boolean);

// Parse each section into a typed structure
type MetaSection = { kind: 'meta'; pairs: { key: string; value: string }[] };
type LabelSection = { kind: 'label'; label: string; items: { text: string; isInstall?: boolean }[] };
type ProseSection = { kind: 'prose'; label: string; paragraphs: string[] };
type FooterSection = { kind: 'footer'; text: string };
type Section = MetaSection | LabelSection | ProseSection | FooterSection;

const parsed: Section[] = sections.map((section): Section => {
  // Footer line
  if (section.startsWith('~*~')) {
    return { kind: 'footer', text: section };
  }

  const lines = section.split('\n').map(l => l.trim()).filter(Boolean);

  // Metadata block: all lines are KEY: VALUE with no leading label
  const isAllMeta = lines.every(l => /^[A-Z ]+:/.test(l) && !l.endsWith(':'));
  if (isAllMeta) {
    return {
      kind: 'meta',
      pairs: lines.map(l => {
        const colon = l.indexOf(':');
        return { key: l.slice(0, colon).trim(), value: l.slice(colon + 1).trim() };
      }),
    };
  }

  // LABEL: section
  const firstLine = lines[0];
  if (firstLine && /^[A-Z ]+:$/.test(firstLine)) {
    const label = firstLine.slice(0, -1);
    const rest = lines.slice(1);
    // List items
    if (rest.every(l => l.startsWith('- '))) {
      return {
        kind: 'label',
        label,
        items: rest.map(l => ({
          text: parseLinks(l.slice(2)),
          isInstall: l.startsWith('- curl'),
        })),
      };
    }
    // Prose paragraphs
    return {
      kind: 'prose',
      label,
      paragraphs: rest.map(l => parseLinks(l)),
    };
  }

  // Fallback: treat as prose with no label
  return { kind: 'prose', label: '', paragraphs: lines.map(l => parseLinks(l)) };
});

const installCmd = 'curl -fsSL https://blaise1030.github.io/workbench-cli/install.sh | sh';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Mission control for parallel AI coding. Workbench is a GUI workspace manager for engineers running multiple Claude Code agents in parallel across git worktrees." />
    <title>Workbench</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <div class="layout">
      <div class="content">

        <div class="brand">WORKBENCH <span class="cursor" aria-hidden="true"></span></div>

        {parsed.map((section) => (
          <>
            <div class="divider">~~~</div>

            {section.kind === 'meta' && (
              <div class="meta-block">
                {section.pairs.map(({ key, value }) => (
                  <div class="row">
                    <span class="label">{key}:</span>{' '}
                    <span class="muted">{value}</span>
                  </div>
                ))}
              </div>
            )}

            {section.kind === 'prose' && (
              <div class="prose-block">
                {section.label && <div class="row"><span class="label">{section.label}:</span></div>}
                {section.paragraphs.map(p => (
                  <p class="prose" set:html={p} />
                ))}
              </div>
            )}

            {section.kind === 'label' && (
              <div class="list-block">
                <div class="row"><span class="label">{section.label}:</span></div>
                {section.items.map(({ text, isInstall }) => (
                  isInstall ? (
                    <div class="install-row">
                      <span class="install-cmd" id="install-cmd">{installCmd}</span>
                      <button class="copy-btn" aria-label="Copy install command">COPY</button>
                    </div>
                  ) : (
                    <div class="list-item">
                      <span class="dash"> -</span>{' '}
                      <span set:html={text} />
                    </div>
                  )
                ))}
              </div>
            )}

            {section.kind === 'footer' && (
              <div class="muted">{section.text}</div>
            )}
          </>
        ))}

      </div>
      <div class="aside"></div>
    </div>

    <style>
      .layout {
        display: grid;
        grid-template-columns: 1fr 1fr;
        min-height: 100vh;
      }

      .aside {
        border-left: 1px solid hsl(var(--border));
      }

      .content {
        padding: 32px 48px;
      }

      .brand {
        font-size: 13px;
        font-weight: 600;
        letter-spacing: 0.08em;
        margin-bottom: 16px;
      }

      .cursor {
        display: inline-block;
        width: 9px;
        height: 1em;
        background: hsl(var(--foreground));
        vertical-align: text-bottom;
        margin-left: 3px;
        animation: blink 1.1s step-end infinite;
      }

      .divider {
        color: hsl(var(--muted-foreground));
        margin: 14px 0;
      }

      .row { margin-bottom: 0; }

      .label {
        font-weight: 600;
        letter-spacing: 0.04em;
      }

      .muted { color: hsl(var(--muted-foreground)); }

      .prose {
        color: hsl(var(--muted-foreground));
        padding-left: 1ch;
      }

      .list-item { color: hsl(var(--muted-foreground)); }
      .list-item .dash { color: hsl(var(--foreground)); }

      .install-row {
        display: flex;
        align-items: center;
        gap: 12px;
        padding-left: 1ch;
        margin-bottom: 4px;
      }

      .install-cmd {
        color: hsl(var(--foreground));
        font-weight: 500;
        font-size: 12px;
      }

      .copy-btn {
        font-family: "Geist Mono Variable", monospace;
        font-size: 10px;
        letter-spacing: 0.1em;
        background: hsl(var(--foreground));
        color: hsl(var(--background));
        border: none;
        padding: 2px 8px;
        cursor: pointer;
        border-radius: 2px;
        flex-shrink: 0;
      }

      .copy-btn:hover { opacity: 0.8; }

      @media (max-width: 600px) {
        .layout { grid-template-columns: 1fr; }
        .aside { display: none; }
        .content { padding: 24px 20px; }
        .install-row {
          flex-direction: column;
          align-items: flex-start;
          gap: 6px;
        }
        .install-cmd {
          font-size: 11px;
          word-break: break-all;
        }
      }
    </style>

    <script>
      const btn = document.querySelector('.copy-btn') as HTMLButtonElement | null;
      const cmdEl = document.getElementById('install-cmd');

      btn?.addEventListener('click', () => {
        const cmd = cmdEl?.textContent ?? '';
        navigator.clipboard.writeText(cmd).then(() => {
          if (btn) {
            btn.textContent = 'COPIED';
            setTimeout(() => { btn.textContent = 'COPY'; }, 1500);
          }
        }).catch(() => {
          if (btn) {
            btn.textContent = 'ERR';
            setTimeout(() => { btn.textContent = 'COPY'; }, 1500);
          }
        });
      });
    </script>
  </body>
</html>
