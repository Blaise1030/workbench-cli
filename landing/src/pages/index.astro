---
import '../styles/global.css';
import rawContent from '../content/landing.md?raw';

function parseLinks(text: string): string {
  return text.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2">$1</a>');
}

const installCmd = 'curl -fsSL https://blaise1030.github.io/workbench-cli/install.sh | sh';

// Render each line to a typed token — 1:1 with landing.md
type Token =
  | { kind: 'divider' }
  | { kind: 'meta'; key: string; value: string }
  | { kind: 'label'; text: string }
  | { kind: 'install' }
  | { kind: 'item'; html: string }
  | { kind: 'text'; html: string }
  | { kind: 'footer'; text: string };

const tokens: Token[] = rawContent.split('\n').flatMap((raw): Token[] => {
  const line = raw.trim();
  if (!line) return [];
  if (line === '~~~') return [{ kind: 'divider' }];
  if (line.startsWith('~*~')) return [{ kind: 'footer', text: line }];
  if (line === '- curl -fsSL https://blaise1030.github.io/workbench-cli/install.sh | sh')
    return [{ kind: 'install' }];
  if (line.startsWith('- ')) return [{ kind: 'item', html: parseLinks(line.slice(2)) }];
  // KEY: (label only, no value)
  if (/^[A-Z][A-Z ]+:$/.test(line)) return [{ kind: 'label', text: line.slice(0, -1) }];
  // KEY: VALUE (meta row)
  const metaMatch = line.match(/^([A-Z][A-Z ]+): (.+)$/);
  if (metaMatch) return [{ kind: 'meta', key: metaMatch[1], value: metaMatch[2] }];
  // Plain text
  return [{ kind: 'text', html: parseLinks(line) }];
});
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Mission control for parallel AI coding. Workbench is a GUI workspace manager for engineers running multiple Claude Code agents in parallel across git worktrees." />
    <title>Workbench</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <div class="layout">
      <div class="content">

        <div class="brand">WORKBENCH <span class="cursor" aria-hidden="true"></span></div>

        {tokens.map((token) => {
          if (token.kind === 'divider')
            return <div class="divider">~~~</div>;
          if (token.kind === 'meta')
            return <div class="row"><span class="label">{token.key}:</span> <span class="muted">{token.value}</span></div>;
          if (token.kind === 'label')
            return <div class="row"><span class="label">{token.text}:</span></div>;
          if (token.kind === 'install')
            return (
              <div class="install-row">
                <span class="install-cmd" id="install-cmd">{installCmd}</span>
                <button class="copy-btn" aria-label="Copy install command">COPY</button>
              </div>
            );
          if (token.kind === 'item')
            return <div class="list-item"><span class="dash"> -</span> <span set:html={token.html} /></div>;
          if (token.kind === 'text')
            return <div class="text" set:html={token.html} />;
          if (token.kind === 'footer')
            return <div class="muted">{token.text}</div>;
        })}

      </div>
      <div class="aside"></div>
    </div>

    <style>
      .layout {
        display: grid;
        grid-template-columns: 1fr 1fr;
        min-height: 100vh;
      }

      .aside {
        border-left: 1px solid hsl(var(--border));
      }

      .content {
        padding: 32px 48px;
      }

      .brand {
        font-size: 13px;
        font-weight: 600;
        letter-spacing: 0.08em;
        margin-bottom: 16px;
      }

      .cursor {
        display: inline-block;
        width: 9px;
        height: 1em;
        background: hsl(var(--foreground));
        vertical-align: text-bottom;
        margin-left: 3px;
        animation: blink 1.1s step-end infinite;
      }

      .divider {
        color: hsl(var(--muted-foreground));
        margin: 14px 0;
      }

      .row { margin-bottom: 0; }

      .label {
        font-weight: 600;
        letter-spacing: 0.04em;
      }

      .muted { color: hsl(var(--muted-foreground)); }

      .text {
        color: hsl(var(--muted-foreground));
        padding-left: 1ch;
      }

      .list-item { color: hsl(var(--muted-foreground)); }
      .list-item .dash { color: hsl(var(--foreground)); }

      .install-row {
        display: flex;
        align-items: center;
        gap: 12px;
        padding-left: 1ch;
        margin-bottom: 4px;
      }

      .install-cmd {
        color: hsl(var(--foreground));
        font-weight: 500;
        font-size: 12px;
      }

      .copy-btn {
        font-family: "Geist Mono Variable", monospace;
        font-size: 10px;
        letter-spacing: 0.1em;
        background: hsl(var(--foreground));
        color: hsl(var(--background));
        border: none;
        padding: 2px 8px;
        cursor: pointer;
        border-radius: 2px;
        flex-shrink: 0;
      }

      .copy-btn:hover { opacity: 0.8; }

      @media (max-width: 600px) {
        .layout { grid-template-columns: 1fr; }
        .aside { display: none; }
        .content { padding: 24px 20px; }
        .install-row {
          flex-direction: column;
          align-items: flex-start;
          gap: 6px;
        }
        .install-cmd {
          font-size: 11px;
          word-break: break-all;
        }
      }
    </style>

    <script>
      const btn = document.querySelector('.copy-btn') as HTMLButtonElement | null;
      const cmdEl = document.getElementById('install-cmd');

      btn?.addEventListener('click', () => {
        const cmd = cmdEl?.textContent ?? '';
        navigator.clipboard.writeText(cmd).then(() => {
          if (btn) {
            btn.textContent = 'COPIED';
            setTimeout(() => { btn.textContent = 'COPY'; }, 1500);
          }
        }).catch(() => {
          if (btn) {
            btn.textContent = 'ERR';
            setTimeout(() => { btn.textContent = 'COPY'; }, 1500);
          }
        });
      });
    </script>
  </body>
</html>
